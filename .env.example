# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# Logging
LOG_LEVEL=info
LOG_PRETTY=true

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_TIME_WINDOW=60000

# CORS
CORS_ORIGIN=*

# Authentication
JWT_SECRET=your-secret-key
JWT_EXPIRES_IN=7d

# Redis (optional)
REDIS_URL=redis://localhost:6379

# Vector Memory (optional)
VECTOR_DB_URL=

# Webhooks
WEBHOOK_SECRET=

# External Services
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=

# ============ Vercel Deployment ============
# Vercel automatically sets these:
# VERCEL=1
# NOW_REGION=ew1
# AWS_LAMBDA_FUNCTION_MEMORY_SIZE (auto)

# Custom env vars for Vercel
VERCEL_URL=
RUNTIME_ENV=vercel
