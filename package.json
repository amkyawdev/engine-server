{
  "name": "engine-server",
  "version": "1.0.0",
  "description": "AI Agent Engine Server with skills, tools, and reasoning capabilities",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "type-check": "tsc --noEmit",
    "prepare": "husky install"
  },
  "keywords": [
    "ai",
    "agent",
    "engine",
    "reasoning",
    "skills",
    "tools"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/websocket": "^10.0.1",
    "fastify": "^4.28.1",
    "zod": "^3.23.8",
    "pino": "^9.2.0",
    "pino-pretty": "^11.2.1",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.9",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^7.16.0",
    "@typescript-eslint/parser": "^7.16.0",
    "eslint": "^8.57.0",
    "husky": "^9.0.11",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "prettier": "^3.3.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
